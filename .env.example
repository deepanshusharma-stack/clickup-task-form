# Copy this to .env.local for local dev, or set these in Vercel project settings for production.

# Required — your ClickUp Personal API Token (Settings → Apps → Generate)
# Treat this like a password. NEVER commit a real token to git.
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — only set this if the form is hosted on a different domain than the API.
# E.g. if the form lives at https://support.gobblecube.ai and the API at https://api.gobblecube.ai,
# set ALLOWED_ORIGIN=https://support.gobblecube.ai. Leave unset for same-origin (default).
# ALLOWED_ORIGIN=https://support.gobblecube.ai
